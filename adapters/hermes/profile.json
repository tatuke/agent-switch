{
  "agent": "hermes",
  "version_range": "0.x",
  "capability_signatures": {
    "search": null,
    "read": null,
    "edit": null,
    "execute": null,
    "fetch": null,
    "diagnostics": null,
    "preview": null
  },
  "native_tools": [],
  "rule_system": {
    "type": "single_file",
    "format": "markdown",
    "global_file": "~/.hermes/AGENTS.md",
    "project_file": "./AGENTS.md",
    "injection": "append_to_system_prompt"
  },
  "tool_permissions": {
    "type": "yaml_config",
    "location": "~/.hermes/config.yaml",
    "format": "settings_map"
  },
  "hook_system": {
    "type": "none",
    "entry": "none"
  },
  "security_boundaries": {
    "never_expose_secrets": true,
    "never_auto_commit": true,
    "never_force_push": true,
    "destructive_requires_confirmation": true
  },
  "session_launch": {
    "command": null,
    "pipe_mode": null,
    "working_directory": "project_root",
    "timeout_seconds": 600,
    "note": "Minimal placeholder, CLI TBD"
  }
}