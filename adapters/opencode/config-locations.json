{
  "agent": "opencode",
  "description": "OpenCode CLI agent configuration locations",
  "paths": {
    "agents_file": {
      "global": "~/.opencode/AGENTS.md",
      "project": "./AGENTS.md",
      "description": "System prompt and agent identity"
    },
    "config": {
      "global": "~/.opencode/config.json",
      "project": "./.opencode/config.json",
      "description": "Tool permissions and agent configuration"
    },
    "memory": {
      "global": "~/.opencode/memory.json",
      "description": "Structured memory store"
    }
  }
}
